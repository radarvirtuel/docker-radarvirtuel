# ─────────────────────────────────────────────────────────────
# .env — docker-radarvirtuel v2
# Copiez ce fichier en .env et renseignez vos valeurs
# cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────

# ── Position de votre station ─────────────────────────────────
# Coordonnées GPS précises — 5 à 6 décimales
FEEDER_LAT=48.607602
FEEDER_LONG=-1.695601
FEEDER_ALT_M=25

# ── Label station ─────────────────────────────────────────────
# Code OACI aéroport le plus proche + numéro (ex: LFPG1, EGLL2, KJFK1)
# Laissez vide pour détection automatique depuis vos coordonnées
RV_STATION_LABEL=

# ── UID station ───────────────────────────────────────────────
# Laissez vide : généré automatiquement au premier démarrage
# et sauvegardé dans le volume Docker (persistant)
RV_STATION_UID=

# ── Informations contributeur ─────────────────────────────────
# Optionnel — affiché sur votre page station publique
RV_CONTRIB_NAME=
RV_CONTRIB_EMAIL=

# ── Source Beast ──────────────────────────────────────────────
# Container ultrafeeder dans le même stack :
#   SOURCE_HOST=ultrafeeder:30005
# readsb/dump1090 standalone sur la même machine :
#   SOURCE_HOST=${HOSTNAME}:30005
# Machine différente sur le réseau local :
#   SOURCE_HOST=192.168.1.10:30005
SOURCE_HOST=${HOSTNAME}:30005
