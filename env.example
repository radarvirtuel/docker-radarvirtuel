# ─────────────────────────────────────────────────────────────
# .env — docker-radarvirtuel v2.0
# cp env.example .env && nano .env
# ─────────────────────────────────────────────────────────────

# ── Contributeur (OBLIGATOIRE) ────────────────────────────────
RV_CONTRIB_NAME=Votre Nom
RV_CONTRIB_EMAIL=votre@email.com

# ── Position de votre station (OBLIGATOIRE) ───────────────────
FEEDER_LAT=48.607602
FEEDER_LONG=-1.695601
FEEDER_ALT_M=25

# ── Source aircraft.json (OBLIGATOIRE) ────────────────────────
# URL HTTP vers aircraft.json de votre décodeur
# Remplacez 192.168.1.x par l'IP de votre machine décodeur
RV_AIRCRAFT_URL=http://192.168.1.x/tar1090/data/aircraft.json

# ── Label station (optionnel) ─────────────────────────────────
# Code OACI aéroport le plus proche + numéro (ex: LFPG1)
# Laissez vide pour détection automatique
RV_STATION_LABEL=

# ── UID station (optionnel) ───────────────────────────────────
# Laissez vide : généré automatiquement depuis CPU serial
RV_STATION_UID=

# ── Options ───────────────────────────────────────────────────
RV_INTERVAL=5
